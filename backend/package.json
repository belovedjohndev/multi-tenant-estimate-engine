{
  "name": "estimate-engine-backend",
  "version": "1.0.0",
  "description": "Backend for estimator engine demo",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "migrate": "psql -f db/migrations/001_initial.sql",
    "migrate:bootstrap": "psql -f db/migrations/001_initial.sql -f db/migrations/002_lead_notifications.sql",
    "migrate:lead-notifications": "psql -f db/migrations/002_lead_notifications.sql",
    "migrate:client-portal": "psql -f db/migrations/003_client_portal_auth.sql",
    "migrate:client-settings": "psql -f db/migrations/004_client_settings_onboarding.sql",
    "migrate:config-versioning": "psql -f db/migrations/005_config_versioning_and_audit.sql",
    "create:client-user": "ts-node src/scripts/createClientPortalUser.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
